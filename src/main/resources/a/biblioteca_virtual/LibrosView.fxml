<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="850.0" spacing="20.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="a.biblioteca_virtual.controller.LibrosController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>

        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
                <Label text="Catálogo de Libros">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="txtBuscar" promptText="Buscar por título o ISBN..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnBuscar" mnemonicParsing="false" text="Buscar" />
                    </children>
                </HBox>
                <TableView fx:id="tablaLibros" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                        <TableColumn fx:id="colTitulo" prefWidth="200.0" text="Título" />
                        <TableColumn fx:id="colIsbn" prefWidth="100.0" text="ISBN" />
                        <TableColumn fx:id="colAnio" prefWidth="70.0" text="Año" />
                        <TableColumn fx:id="colGenero" prefWidth="120.0" text="Género" />
                        <TableColumn fx:id="colDisponible" prefWidth="75.0" text="Disponibles" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <VBox prefWidth="320.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 5;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Detalles del Libro">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Título" />
                        <TextField fx:id="txtTitulo" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="ISBN" />
                        <TextField fx:id="txtIsbn" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Año de Publicación" />
                        <TextField fx:id="txtAnio" promptText="Ej. 2023" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Género" />
                        <TextField fx:id="txtGenero" promptText="Ej. Ciencia Ficción" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Autor" />
                        <ComboBox fx:id="cbAutor" maxWidth="1.7976931348623157E308" promptText="Seleccionar Autor" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Editorial" />
                        <ComboBox fx:id="cbEditorial" maxWidth="1.7976931348623157E308" promptText="Seleccionar Editorial" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Cantidad Disponible" />
                        <Spinner fx:id="spnCantidad" maxWidth="1.7976931348623157E308" />
                    </children>
                </VBox>

                <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardarLibro" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Guardar" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#limpiarFormulario" text="Limpiar" />
                    </children>
                </HBox>
                <Button fx:id="btnEliminar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#eliminarLibro" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Eliminar Seleccionado" />
            </children>
        </VBox>

    </children>
</HBox>