<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #f4f6f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="a.biblioteca_virtual.controller.AutorController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label text="Catálogo de Autores" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="txtNombre" prefHeight="40.0" promptText="Nombre completo del autor..." style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 3;" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="txtNacionalidad" prefHeight="40.0" prefWidth="200.0" promptText="Nacionalidad..." style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 3;"/>
        <DatePicker fx:id="dpFechaNacimiento" prefHeight="40.0" prefWidth="170.0" promptText="Nacimiento" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 3;"/>

        <Button mnemonicParsing="false" onAction="#guardarAutor" prefHeight="40.0" style="-fx-background-color: #e2e8f0; -fx-text-fill: #333333; -fx-cursor: hand;" text="Guardar Autor">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </Button>

        <Button mnemonicParsing="false" onAction="#limpiarFormulario" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-cursor: hand; -fx-underline: true;" text="Limpiar" />
    </HBox>

    <TableView fx:id="tablaAutores" style="-fx-border-color: #dcdde1; -fx-border-radius: 3;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" maxWidth="100.0" minWidth="50.0" prefWidth="80.0" style="-fx-alignment: CENTER;" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="350.0" text="Nombre" />
            <TableColumn fx:id="colNacionalidad" prefWidth="200.0" text="Nacionalidad" />
            <TableColumn fx:id="colFechaNacimiento" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Nacimiento" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button mnemonicParsing="false" onAction="#eliminarAutor" prefHeight="45.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" text="Eliminar Seleccionado">
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
        </Button>
    </HBox>

</VBox>