<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="a.biblioteca_virtual.controller.UsuariosController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>

        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
                <Label text="Gestión de Usuarios">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="txtBuscar" promptText="Buscar por nombre o correo..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnBuscar" mnemonicParsing="false" text="Buscar" />
                    </children>
                </HBox>
                <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="150.0" text="Nombre Completo" />
                        <TableColumn fx:id="colCorreo" prefWidth="120.0" text="Correo" />
                        <TableColumn fx:id="colUsername" prefWidth="90.0" text="Usuario" />
                        <TableColumn fx:id="colRol" prefWidth="70.0" text="Rol" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 5;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Datos del Usuario">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Nombre Completo" />
                        <TextField fx:id="txtNombre" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Correo Electrónico" />
                        <TextField fx:id="txtCorreo" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Nombre de Usuario (Username)" />
                        <TextField fx:id="txtUsername" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Contraseña" />
                        <PasswordField fx:id="txtPassword" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Rol en el Sistema" />
                        <ComboBox fx:id="cbRol" maxWidth="1.7976931348623157E308" promptText="Seleccionar Rol" />
                    </children>
                </VBox>

                <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardarUsuario" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Guardar" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#limpiarFormulario" text="Limpiar" />
                    </children>
                </HBox>
                <Button fx:id="btnEliminar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#eliminarUsuario" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Eliminar Seleccionado" />
            </children>
        </VBox>

    </children>
</HBox>
